# OpenAI API key — required for the gpt-4o-mini chat call.
# Swap the model in app/api/chat/route.ts to use Anthropic / Google / etc.
OPENAI_API_KEY=sk-...

# Project name used as the namespace for Prism MCP memory.
# Change this if you want to share memory across multiple deployments.
PRISM_PROJECT=vercel-ai-sdk-demo
