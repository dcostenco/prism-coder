{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/post-commit-repomix.sh",
            "if": "Bash(git commit*)",
            "async": true,
            "timeout": 60
          }
        ]
      }
    ]
  }
}
